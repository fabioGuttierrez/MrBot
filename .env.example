# Django
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# -- Docker local --
POSTGRES_DB=mrbot
POSTGRES_USER=mrbot
POSTGRES_PASSWORD=mrbot123
DATABASE_URL=postgres://mrbot:mrbot123@db:5432/mrbot

# -- Supabase (produção) — descomente e substitua --
# DATABASE_URL=postgres://postgres.[ref]:[senha]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# DB_CONN_MAX_AGE=0   # usar 0 com o pooler do Supabase (PgBouncer); 60 para conexão direta

# Redis
REDIS_URL=redis://redis:6379/0

# OpenAI
OPENAI_API_KEY=sk-...

# UazAPI
UAZAPI_BASE_URL=https://your-uazapi-instance.com
UAZAPI_GLOBAL_TOKEN=your-global-token

# App
APP_BASE_URL=http://localhost:8000
WEBHOOK_SECRET=change-this-webhook-secret
