# ============================================================
# MrBot — Variáveis de ambiente para PRODUÇÃO (VPS)
# Copie este arquivo para .env e preencha todos os campos
# ============================================================

# Django
DEBUG=False
SECRET_KEY=gere-uma-chave-forte-aqui-use-openssl-rand-base64-50
ALLOWED_HOSTS=seudominio.com,www.seudominio.com

# Database (Supabase ou PostgreSQL externo)
DATABASE_URL=postgres://postgres:SENHA@db.XXXX.supabase.co:5432/postgres?sslmode=require
DB_CONN_MAX_AGE=60

# Redis (container local via docker-compose.prod.yml)
REDIS_URL=redis://redis:6379/0

# OpenAI
OPENAI_API_KEY=sk-...

# UazAPI
UAZAPI_BASE_URL=https://api.seuuazapi.com
UAZAPI_GLOBAL_TOKEN=seu-admin-token

# App
APP_BASE_URL=https://seudominio.com
WEBHOOK_SECRET=senha-secreta-para-webhook-uazapi

# E-mail (opcional — para notificações)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu@email.com
EMAIL_HOST_PASSWORD=sua-senha-app
